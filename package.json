{
  "name": "@open-bridge/core",
  "version": "0.3.0",
  "description": "Open Bridge. Vendor-independent runtime abstraction for AI coding agents.",
  "main": "index.js",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "index.js",
    "interface.js",
    "instructions.js",
    "host-integration.js",
    "mcp-bridge-server.js",
    "codex-app-server.js",
    "adapters/"
  ],
  "keywords": [
    "ai",
    "agent",
    "runtime",
    "abstraction",
    "adapter",
    "bridge",
    "claude",
    "opencode",
    "codex"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/chadbyte/open-bridge.git"
  },
  "bugs": {
    "url": "https://github.com/chadbyte/open-bridge/issues"
  },
  "homepage": "https://github.com/chadbyte/open-bridge#readme",
  "author": "Chad Lee",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.132",
    "@anthropic-ai/claude-code": "^2.1.137",
    "zod": "^3.25.0 || ^4.0.0"
  },
  "optionalDependencies": {
    "@openai/codex": "^0.142.4"
  },
  "devDependencies": {
    "semantic-release": "^24.0.0"
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      [
        "@semantic-release/commit-analyzer",
        {
          "preset": "angular"
        }
      ],
      "@semantic-release/release-notes-generator",
      "@semantic-release/npm",
      "@semantic-release/github"
    ]
  }
}
